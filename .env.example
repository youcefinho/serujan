# ── Côté client (Vite — injectées dans le bundle) ────
VITE_CALENDLY_URL=https://calendly.com/votre-courtier/consultation
VITE_GA4_ID=G-XXXXXXXXXX

# ── Côté serveur (Cloudflare Dashboard uniquement) ───
# ⚠️ NE PAS mettre ces valeurs ici !
# Les configurer dans : Cloudflare → Workers & Pages → Settings → Variables et secrets
#
# ADMIN_PASSWORD=votre-mot-de-passe-admin
# RESEND_API_KEY=re_votre-cle-resend
# GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/VOTRE_WEBHOOK_ID  (optionnel — GoHighLevel)
