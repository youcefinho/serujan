# ═══════════════════════════════════════════════════════════════
# INTRALYS — Variables d'environnement requises
# ═══════════════════════════════════════════════════════════════
# Copiez ce fichier vers .env.local et remplissez les valeurs.
#   cp .env.example .env.local
# ═══════════════════════════════════════════════════════════════

# ── Cloudflare (variables serveur — configurer dans le Dashboard) ──

# Mot de passe admin pour accéder au panel /admin
# À configurer dans Cloudflare → Workers & Pages → Settings → Variables
ADMIN_PASSWORD=choisir-un-mot-de-passe-fort

# ── Resend (resend.com → API Keys) ───────────────────────────
# Clé API pour l'envoi du Lead Magnet (guide PDF par email)
# À configurer dans Cloudflare → Workers & Pages → Settings → Variables
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXX

# ── Google Analytics 4 (GA4 Admin → Data Streams) ────────────
# ID de mesure GA4 — laisser G-XXXXXXXXXX si pas encore créé
VITE_GA4_ID=G-XXXXXXXXXX

# ── Calendly ─────────────────────────────────────────────────
# URL de la page de prise de rendez-vous du courtier
VITE_CALENDLY_URL=https://calendly.com/VOTRE-LIEN
